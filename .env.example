# .env.example
# Copy this file to .env and fill in the values

# --- macOS & Linux Users ---
# Set APPDATA to a local directory (usually '.') to avoid Docker volume mount errors 
# that rely on the Windows-only AppData folder.
# APPDATA=.

# --- Twitter Integration ---
# Required for background jobs that tweet new entries.
YND_Twitter__ConsumerKey=
YND_Twitter__ConsumerSecret=
YND_Twitter__AccessToken=
YND_Twitter__AccessTokenSecret=
