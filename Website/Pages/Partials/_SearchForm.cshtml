@model int
@using Application.Services.MultiLanguage
@using Website.Resources

@inject Microsoft.Extensions.Localization.IStringLocalizer<Messages> Localizer
@inject ILanguageService LanguageService

@{
    string bgImagePath = "";

    if (LanguageService.IsYoruba)
    {
        bgImagePath = "/img/bg/yorubaname-bg.jpg";
    }
    else if (LanguageService.IsIgbo)
    {
        bgImagePath = "/img/bg/igboname-bg.jpg";
    }
}

<section class="hero-section d-flex align-items-center" style="background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.2)), url('@bgImagePath'); background-size: cover; background-position: center;">
    <div class="container text-center text-white">
        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-8">
                
                <h1 class="display-4 text-white fw-bold mb-3">
                    @Localizer["jumbotron1"]
                </h1>

                <p class="text-white mb-5 fs-4">
                    @Localizer["jumbotron2", Model, LanguageService.LanguageDisplay]
                </p>

                <div class="mx-auto">
                    @await Html.PartialAsync("Partials/_SearchComponent")
                </div>

            </div>
        </div>
    </div>
</section>